EXPO_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_javascript_key_here
# Register this origin in Kakao Developers > Web platform domains.
EXPO_PUBLIC_KAKAO_MAP_WEB_ORIGIN=https://catdex.local
# Expo Go Android emulator: exp://127.0.0.1:8081
# Development build: catdex://
EXPO_PUBLIC_OAUTH_REDIRECT_URI=

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# RevenueCat public SDK keys
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your_public_sdk_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your_public_sdk_key_here
