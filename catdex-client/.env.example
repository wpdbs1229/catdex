# Local app variant. EAS production builds set this automatically through eas.json.
# development -> 냥도감 Dev / catdex-dev:// / com.persimmontree.catdex.dev
# production  -> 냥도감 / catdex:// / com.persimmontree.catdex
APP_VARIANT=development

# Kakao
EXPO_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_javascript_key_here
EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=your_kakao_native_app_key_here
# Register this origin in Kakao Developers > Web platform domains. Leave empty for local development builds.
EXPO_PUBLIC_KAKAO_MAP_WEB_ORIGIN=
# Expo Go local simulator: exp://127.0.0.1:8082
# Development build: catdex-dev://auth/callback
# Production build: catdex://auth/callback
# Supabase Auth > URL Configuration > Redirect URLs에도 같은 값을 등록해야 합니다.
EXPO_PUBLIC_OAUTH_REDIRECT_URI=catdex-dev://auth/callback

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
