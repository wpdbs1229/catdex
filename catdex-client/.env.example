# Kakao Maps JavaScript SDK key.
# Do not use REST API/Admin keys here.
EXPO_PUBLIC_KAKAO_MAP_APP_KEY=your_kakao_javascript_key_here
# Use an http(s) origin only: scheme + host + optional port, no path.
# Register this exact origin in Kakao Developers > App > Platform > Web > JavaScript SDK domain.
EXPO_PUBLIC_KAKAO_MAP_WEB_ORIGIN=https://catdex.local
# Expo Go local simulator: exp://127.0.0.1:8082
# Development build: catdex://auth/callback
# Supabase Auth > URL Configuration > Redirect URLs에도 같은 값을 등록해야 합니다.
EXPO_PUBLIC_OAUTH_REDIRECT_URI=

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# RevenueCat public platform API keys.
# Do not put RevenueCat secret keys or Supabase service role keys in Expo public env values.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your_revenuecat_ios_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your_revenuecat_android_key_here
